# Copy to env.local and fill in paths (env.local is gitignored).
# Scripts auto-source env.local from this repo root when you run them from scripts/ here.
# Or set BEAM_GMT_ENV_FILE to any file path to load roots from elsewhere.
#
#   cp env.example env.local
#   $EDITOR env.local
#
# All paths should be the **root directories** of each checkout (no trailing slash required).

# Green Metrics Tool — directory that contains runner.py (update when you relocate GMT).
GMT_ROOT=

# This repository (beam-gmt-benchmarks) — optional; default is the folder that contains usage_scenario.yml
# next to scripts/. Override if scripts are invoked from an unusual layout.
# BEAM_GMT_BENCHMARKS_ROOT=

# BEAM-web-server-benchmarks clone — required for run_gmt_http_sweep.sh static|dynamic|all discovery
# BEAM_ROOT=

# Optional: Python used to execute runner.py (default: ${GMT_ROOT}/.venv/bin/python3, then python3)
# GMT_PYTHON=
