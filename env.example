# Optional overrides only. If you use the default folder layout, you do not need env.local.
#
# Hosted measurements: see README.md and docs/CLUSTER_AND_GITHUB.md (request form variable keys:
# BEAM_IMAGE, NUM_REQUESTS, SWEEP_EXTRA — not the full __GMT_VAR_...__ string).
#
# Default layout (auto-detected, no exports):
#   workspace/
#     green-metrics-tool/          # contains runner.py, lib/scenario_runner.py
#     BEAM-web-server-benchmarks/   # contains benchmarks/static
#     beam-gmt-benchmarks/         # this repo
#
# Scripts walk upward from beam-gmt-benchmarks and look for those sibling directories.
#
# Uncomment and fill only when auto-discovery fails (custom paths or names):

# GMT_ROOT=
# BEAM_GMT_BENCHMARKS_ROOT=
# BEAM_ROOT=

# GMT_PYTHON=

# BEAM_GMT_VERBOSE=1   # print which roots were auto-detected
# BEAM_GMT_ENV_FILE=    # optional: source another file before env.local

# --- Many laptops: GMT aborts RAPL energy providers with "RAPL energy filtering is active" (MSR 0xBC). Uncomment to proceed (local/dev only; see docs/ENERGY_METRICS.md). ---
# export GMT_IGNORE_RAPL_ENERGY_FILTERING_CHECK=1
